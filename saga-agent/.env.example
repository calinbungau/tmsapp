# TMS connection
TMS_BASE_URL=https://your-tms.example.com

# Credentials generated in TMS -> Admin -> Settings -> Integrations -> Saga & API
TMS_API_KEY=tms_xxxxxxxxxxxxxxxxxxxxxxxx
TMS_API_USERNAME=saga-agent
TMS_API_SECRET=your-secret-shown-once

# Polling interval (milliseconds)
POLL_INTERVAL_MS=60000

# Saga Firebird DB connection is configured via CONN_STRING in agent.js.
# Adjust the DBNAME path / UID / PWD there to match your Saga installation.

{
  "installCommand": "pnpm install",
  "buildCommand": "node .v0/inject-built-with-v0.mjs && next build",
  "crons": [
    {
      "path": "/api/cron/maintenance-check",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/action-center",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/action-center-digest",
      "schedule": "0 7 * * *"
    }
  ]
}
